# Application
APP_NAME=CivicPulse Run API
DEBUG=false

# Database (async for app, sync for alembic)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/run_api
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/run_api

# ZITADEL Authentication (service account for backend API calls)
# For local dev: these are auto-populated in .env.zitadel by the bootstrap container.
# For remote: set these to your production ZITADEL instance values.
ZITADEL_ISSUER=https://auth.civpulse.org
ZITADEL_PROJECT_ID=your-project-id
ZITADEL_SERVICE_CLIENT_ID=your-service-client-id
ZITADEL_SERVICE_CLIENT_SECRET=your-service-client-secret

# ZITADEL SPA (public OIDC client for browser — served via /api/v1/config/public)
ZITADEL_SPA_CLIENT_ID=your-spa-client-id

# Local ZITADEL (auto-populated by zitadel-bootstrap container on first run)
# See .env.zitadel after running: docker compose up
# ZITADEL_DOMAIN=localhost              # or dev.tailb56d83.ts.net for Tailscale
# ZITADEL_BASE_URL=http://zitadel:8080  # set automatically in docker-compose

# CORS
CORS_ALLOWED_ORIGINS='["http://localhost:5173"]'

# S3-compatible object storage (MinIO local, Cloudflare R2 production)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=voter-imports
S3_REGION=us-east-1

# --- ZITADEL Credentials (defaults work for local dev) ---
# Override these for shared/staging environments:
# ZITADEL_MASTERKEY=<32-char-key>
# ZITADEL_DB_NAME=zitadel
# ZITADEL_DB_USER=zitadel
# ZITADEL_DB_PASSWORD=<strong-password>
# ZITADEL_ADMIN_PASSWORD=<strong-password>
# Set to "true" to disable TLS for local development without Tailscale
# DISABLE_TLS=false
