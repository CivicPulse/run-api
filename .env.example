# Application
APP_NAME=CivicPulse Run API
DEBUG=false

# Database (async for app, sync for alembic)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/run_api
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/run_api

# ZITADEL Authentication (service account for backend API calls)
ZITADEL_ISSUER=https://auth.civpulse.org
ZITADEL_PROJECT_ID=your-project-id
ZITADEL_SERVICE_CLIENT_ID=your-service-client-id
ZITADEL_SERVICE_CLIENT_SECRET=your-service-client-secret

# ZITADEL SPA (public OIDC client for browser — served via /api/v1/config/public)
ZITADEL_SPA_CLIENT_ID=your-spa-client-id

# CORS
CORS_ALLOWED_ORIGINS='["http://localhost:5173"]'

# S3-compatible object storage (MinIO local, Cloudflare R2 production)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=voter-imports
S3_REGION=us-east-1
