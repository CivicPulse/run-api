# Application
APP_NAME=CivicPulse Run API
DEBUG=false

# Host port assignments — all in the 378xx range to avoid conflicts with other projects.
# Run `scripts/bootstrap-dev.sh` for a clean start; it auto-detects your Tailscale
# FQDN, generates the TLS cert, and brings up docker compose.
API_HOST_PORT=37821
WEB_HOST_PORT=37822
ZITADEL_EXTERNAL_PORT=37823
PG_HOST_PORT=37824
ZITADEL_DB_HOST_PORT=37825
MINIO_HOST_PORT=37826
MINIO_CONSOLE_HOST_PORT=37827

# Database (async for app, sync for alembic)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/run_api
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/run_api

# ZITADEL Authentication (service account for backend API calls)
# For local dev: auto-populated in .env.zitadel by the bootstrap container.
# For remote: set these to your production ZITADEL instance values.
ZITADEL_ISSUER=https://auth.civpulse.org
ZITADEL_PROJECT_ID=your-project-id
ZITADEL_SERVICE_CLIENT_ID=your-service-client-id
ZITADEL_SERVICE_CLIENT_SECRET=your-service-client-secret

# ZITADEL SPA (public OIDC client for browser — served via /api/v1/config/public)
ZITADEL_SPA_CLIENT_ID=your-spa-client-id

# Local ZITADEL — Tailscale domain (bootstrap-dev.sh fills this in automatically)
# Replace with your machine's Tailscale FQDN (e.g. myhost.tailXXXXX.ts.net)
ZITADEL_DOMAIN=your-machine.tailXXXXX.ts.net
ZITADEL_TLS_MODE=enabled
ZITADEL_EXTERNAL_SECURE=true

# CORS — include the Tailscale HTTPS origin for the frontend
CORS_ALLOWED_ORIGINS='["https://your-machine.tailXXXXX.ts.net:37822","http://localhost:37822"]'

# S3-compatible object storage (MinIO local, Cloudflare R2 production)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=voter-imports
S3_REGION=us-east-1

# --- ZITADEL Credentials (defaults work for local dev) ---
# Override these for shared/staging environments:
# ZITADEL_MASTERKEY=<32-char-key>
# ZITADEL_DB_NAME=zitadel
# ZITADEL_DB_USER=zitadel
# ZITADEL_DB_PASSWORD=<strong-password>
# ZITADEL_ADMIN_PASSWORD=<strong-password>
# Disable uvicorn TLS — Vite proxies to the API over internal Docker HTTP
DISABLE_TLS=true
