# Copy this file to .env.run-api.secrets and fill in real values.
# DO NOT commit .env.run-api.secrets to source control.
#
# Usage:
#   kubectl create secret generic run-api-secret \
#     --namespace=civpulse-dev \
#     --from-env-file=.env.run-api.secrets

DATABASE_URL=postgresql+asyncpg://user:password@postgres-host:5432/run_api
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@postgres-host:5432/run_api
ZITADEL_ISSUER=https://auth.civpulse.org
ZITADEL_PROJECT_ID=your-project-id
ZITADEL_SERVICE_CLIENT_ID=your-client-id
ZITADEL_SERVICE_CLIENT_SECRET=your-client-secret
ZITADEL_SPA_CLIENT_ID=your-spa-client-id
S3_ENDPOINT_URL=https://your-s3-endpoint
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=voter-imports
S3_REGION=us-east-1
